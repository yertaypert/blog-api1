#: apps/blog/views.py:96
msgid "Authentication required."
msgstr "Аутентификация қажет."

#: apps/blog/views.py:100
msgid "Comment body cannot be empty."
msgstr "Пікір мәтіні бос болмауы керек."

#: apps/users/models.py:47
msgid "English"
msgstr "Ағылшын тілі"

#: apps/users/models.py:48
msgid "Russian"
msgstr "Орыс тілі"

#: apps/users/models.py:49
msgid "Kazakh"
msgstr "Қазақ тілі"

#: apps/users/serializers.py:16
msgid "Password is required."
msgstr "Құпия сөзді енгізу қажет."

#: apps/users/serializers.py:17
msgid "Password cannot be empty."
msgstr "Құпия сөз бос болмауы керек."

#: apps/users/serializers.py:24
msgid "Password confirmation is required."
msgstr "Құпия сөзді растау қажет."

#: apps/users/serializers.py:25
msgid "Password confirmation cannot be empty."
msgstr "Құпия сөзді растау бос болмауы керек."

#: apps/users/serializers.py:35
msgid "Password fields didn't match."
msgstr "Құпия сөздер сәйкес келмеді."

#: apps/users/serializers.py:41
msgid "User with this email already exists."
msgstr "Бұл электрондық поштасы бар пайдаланушы тіркелген."

#: apps/users/validators.py:11
msgid "Invalid timezone identifier."
msgstr "Уақыт белдеуінің идентификаторы қате."

#: apps/users/views.py:49
msgid "Too many requests. Try again later."
msgstr "Сұраныс тым көп. Кейінірек қайталап көріңіз."